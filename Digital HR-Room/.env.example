# ============================================================
# Digital HR-Room — Environment Variables Template
# Copy this file to the appropriate .env location per service
# ============================================================

# === BACKEND (.env) ===
PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/digital-hr-room
AI_SERVICE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
UMURAVA_API_URL=
UMURAVA_API_KEY=

# === AI SERVICE (.env) ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
AI_SERVICE_PORT=8000

# === FRONTEND (.env.local) ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME=Digital HR-Room
